{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "fg_jade" : "#19D08A",
    "bg_jade" : "#233C3F"
  },
  "console_title_template": "{{if .Root}}[root] {{end}}{{.Shell}} in <{{.Folder}}>",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "foreground": "p:fg_jade",
          "background": "p:bg_jade",
          "leading_diamond": "",
          "template": "  ",
          "style": "diamond",
          "trailing_diamond": "",
          "type": "text"
        },
        {
          "foreground": "p:bg_jade",
          "background": "p:fg_jade",
          "leading_diamond": "",
          "template": "{{ if .SSHSession }}\ueba9 {{ end }}{{ .UserName }}@{{ .HostName }}",
          "style": "diamond",
          "trailing_diamond": "",
          "type": "session"
        },
        {
          "background": "p:bg_jade",
          "foreground": "p:fg_jade",
          "leading_diamond": "",
          "trailing_diamond": "",
          "template": "  {{ .Path }} ",
          "properties": {
            "style": "agnoster_short"
          },
          "style": "diamond",
          "type": "path"
        },
        {
          "properties": {
            "cache_duration": "none",
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "leading_diamond": "",
          "trailing_diamond": "",
          "background": "p:bg_jade",
          "foreground": "p:fg_jade",
          "type": "git",
          "style": "diamond",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#233C3F{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#233C3F{{ end }}",
            "{{ if gt .Ahead 0 }}#233C3F{{ end }}",
            "{{ if gt .Behind 0 }}#233C3F{{ end }}"
          ]
        },
        {
          "properties": {
            "always_enabled": true,
            "cache_duration": "none"
          },
          "trailing_diamond": "\ue0b0",
          "template": " {{ if gt .Code 0 }}\uf00d {{ else }}\uf42e {{ end }}",
          "foreground": "p:bg_jade",
          "background": "p:fg_jade",
          "type": "status",
          "style": "diamond",
          "background_templates": [
            "{{ if gt .Code 0 }}#BB6666{{ end }}"
          ]
        }
      ],
      "newline": true
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "time",
          "style": "diamond",
          "foreground": "p:fg_jade",
          "template": "\ue641 {{.CurrentDate | date .Format }}"
        },
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "| \uf489 {{ .Name }}",
          "foreground": "p:fg_jade",
          "type": "shell",
          "style": "diamond"
        }
      ],
      "newline": true
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "always_enabled": true,
            "cache_duration": "none"
          },
          "template": "",
          "foreground": "p:fg_jade",
          "background": "transparent",
          "type": "status",
          "style": "plain",
          "foreground_templates": [
            "{{if gt .Code 0}}#BB6666{{end}}"
          ]
        }
      ],
      "newline": true
    }
  ],
  "version": 3,
  "final_space": true
}