# PATH
export PATH=$HOME/.local/bin:$PATH
export PATH=$PATH:/opt/nvim-linux-x86_64/bin
export PATH=$PATH:$HOME/.opencode/bin

# load init and custom modulars
[ -f ~/.config/bash/init.sh ] && source ~/.config/bash/init.sh

# shells
if command -v starship &>/dev/null; then
  eval "$(starship init bash)"
fi

# tmux - auto start session
if command -v tmux &>/dev/null && [ -z "$TMUX" ]; then
  tmux new-session -d -s dev
  tmux attach -t dev
fi

# tmux - handle devbox integration
if [ -n "$TMUX" ] && [ -n "$DEVBOX_SHELL_ENABLED" ]; then
  original_name=$(tmux display-message -p '#W')

  case "$original_name" in
  devbox:*) ;;
  *)
    tmux rename-window "devbox:$original_name"
    ;;
  esac

  trap '
    current=$(tmux display-message -p "#W" 2>/dev/null)

    case "$current" in
      devbox:*)
        new_name="${current#devbox:}"
        tmux rename-window "$new_name"
        ;;
    esac
  ' EXIT
fi

