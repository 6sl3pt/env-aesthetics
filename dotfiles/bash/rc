# PATH
export PATH=$PATH:$HOME/.local/bin
export PATH=$PATH:/opt/nvim-linux-x86_64/bin
export PATH=$PATH:$HOME/.opencode/bin
export PATH=$PATH:$HOME/.cargo/bin
. "$HOME/.cargo/env"

# load init and custom modulars
[ -f ~/.config/bash/init.sh ] && source ~/.config/bash/init.sh

# shells
if command -v starship &>/dev/null; then
  eval "$(starship init bash)"
fi

if command -v direnv &>/dev/null; then
  eval "$(direnv hook bash)"
fi

# tmux - auto start session
if command -v tmux &>/dev/null && [ -z "$TMUX" ]; then
  tmux has-session -t dev 2>/dev/null

  if [ $? != 0 ]; then
    tmux new-session -d -s dev -n editor 'nvim; bash'

    if command -v spotify_player &>/dev/null; then
      tmux new-window -t dev:9 -n spotify 'spotify_player; bash'
    fi
  fi

  tmux attach-session -t dev
fi
