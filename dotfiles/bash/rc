# git - convert -f to --force-with-lease
git() {
  if [[ "$1" == "push" ]]; then
    args=()
    replaced=false

    for arg in "${@:2}"; do
      case "$arg" in
      -f | --force)
        args+=("--force-with-lease")
        replaced=true
        ;;
      *)
        args+=("$arg")
        ;;
      esac
    done

    if [ "$replaced" = true ]; then
      echo -e "\e[1;33mConverting force push to --force-with-lease\e[0m" >&2
    fi

    command git push "${args[@]}"
  else
    command git "$@"
  fi
}

# shells
if command -v starship &>/dev/null; then
  eval "$(starship init bash)"
fi

# tmux - auto start session
if command -v tmux &>/dev/null && [ -z "$TMUX" ]; then
  tmux new-session -d -s dev
  tmux attach -t dev
fi

# tmux - handle devbox integration
if [ -n "$TMUX" ] && [ -n "$DEVBOX_SHELL_ENABLED" ]; then
  original_name=$(tmux display-message -p '#W')

  case "$original_name" in
  devbox:*) ;;
  *)
    tmux rename-window "devbox:$original_name"
    ;;
  esac

  trap '
    current=$(tmux display-message -p "#W" 2>/dev/null)

    case "$current" in
      devbox:*)
        new_name="${current#devbox:}"
        tmux rename-window "$new_name"
        ;;
    esac
  ' EXIT
fi

# Opencode - OpenAI compatible API configs
export AI_BASE_URL=
export AI_API_KEY=

ai() {
  NC='\033[0m'
  RED='\033[0;31m'
  GREEN='\033[0;32m'

  if [ -z "$AI_BASE_URL" ]; then
    echo -e "${RED}Ô£İ ERROR: AI_BASE_URL is not set${NC}"
    return 1
  fi

  if [ -z "$AI_API_KEY" ]; then
    echo -e "${RED}Ô£İ ERROR: AI_API_KEY is not set${NC}"
    return 1
  fi

  case "$1" in
  list)
    curl -s "$AI_BASE_URL/models" \
      -H "Authorization: Bearer $AI_API_KEY" |
      jq -r '.data[].id' |
      sed 's/^/ÔÇó /'
    ;;

  ping)
    if [ -z "$2" ]; then
      echo "Usage: model ping <model-id>"
      return 1
    fi

    response=$(curl -s -w "%{http_code}" "$AI_BASE_URL/chat/completions" \
      -H "Authorization: Bearer $AI_API_KEY" \
      -H "Content-Type: application/json" \
      -d "{
          \"model\": \"$2\",
          \"messages\": [
            {\"role\": \"user\", \"content\": \"Hello\"}
          ],
          \"max_tokens\": 10000,
          \"temperature\": 0.7
        }")

    http_status="${response: -3}"
    body="${response:0:-3}"

    if [ "$http_status" -ge 400 ]; then
      echo -e "${RED}Ô£İ HTTP Error $http_status${NC}"
    fi

    content=$(echo "$body" | jq -r '.choices[0].message.content // "empty"' 2>/dev/null)
    echo -e "${GREEN}Ô£ô $content${NC}"
    ;;

  *)
    echo "Usage:"
    echo "  ai list"
    echo "  ai ping <model-id>"
    ;;
  esac
}
